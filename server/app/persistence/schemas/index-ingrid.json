                }
              },
              "required": [
                "data_type"
              ]
            }
          ]
        },
        "temporal": {
          "type": "object",
          "description": "Enthält zusätzliche Informationen zur Aktualität des Datensatzes, einschließlich Status, Pflegeintervall und benutzerdefinierten Pflegeintervall.",
          "unevaluatedProperties": false,
          "allOf": [
            {
              "type": "object",
              "properties": {
                "data_temporal": {
                  "type": "array",
                  "items": {
                    "type": "object",
