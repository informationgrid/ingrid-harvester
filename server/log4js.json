{
  "appenders": {
    "console": {
      "type": "console",
      "layout": {
        "type": "json"
      },
      "enableCallstack": true
    },
    "appLog": {
      "type": "file",
      "filename": "logs/app.log",
      "maxLogSize": 10485760,
      "backups": 5,
      "layout": {
        "type": "pattern",
        "pattern": "[%d{ISO8601_WITH_TZ_OFFSET}] [%p] %c - %m"
      }
    },
    "summaryFile": {
      "type": "file",
      "filename": "logs/summary.log",
      "maxLogSize": 10485760,
      "backups": 3,
      "layout": {
        "type": "pattern",
        "pattern": "[%d{ISO8601_WITH_TZ_OFFSET}] [%p] %c - %m"
      }
    }
  },
  "categories": {
    "default": {
      "appenders": [ "console", "appLog" ],
      "level": "INFO"
    },
    "summary": {
      "appenders": [ "console", "summaryFile", "appLog" ],
      "level": "INFO"
    },
    "requests": {
      "appenders": [ "console", "appLog" ],
      "level": "INFO"
    }
  }
}
