{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": false,
    "baseUrl": ".",
    "outDir": "./dist/out-tsc",
    "declaration": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "typeRoots": [
      "node_modules/@types"
    ],
    "lib": [
      "es2022",
      "dom"
    ],
    "paths": {
      "@shared/*": [
        "../shared/*"
      ],
      "tslib": [
        "node_modules/tslib"
      ]
    },
    "useDefineForClassFields": false
  },
  "exclude": [
    "cypress",
    "cypress.config.ts",
    "src/**/*.spec.ts"
  ]
}
